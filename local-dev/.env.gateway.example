# Variáveis de ambiente para desenvolvimento local do livia-gateway
# Copiar para .env.gateway e preencher os valores
#
# MODO SIMPLES (padrão): aponta para Supabase staging
# MODO FULL (--profile full): usar SUPABASE_URL vazio, gateway conecta ao postgres local

# ── Gateway ───────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=debug

# Shadow mode: true = só loga, não persiste nem faz forward
# Recomendado true para primeiros testes
SHADOW_MODE=true

# Dual write: true = persiste no Supabase + faz forward para n8n em paralelo
DUAL_WRITE=false

# API key para autenticar chamadas ao gateway (Evolution usa este header)
GATEWAY_API_KEY=gw-dev-local-key

# ── n8n webhook (destino dos forwards) ───────────────────────────────────────
# Modo simples: aponta para o webhook-echo local
N8N_WEBHOOK_URL=http://webhook-echo:8080/webhook/test

# Modo full (descomente): aponta para o n8n local
# N8N_WEBHOOK_URL=http://n8n:5678/webhook/dev_integrator

# ── Supabase (staging) ────────────────────────────────────────────────────────
# Modo simples: usar staging Supabase para persistência
SUPABASE_URL=https://qejxaqqfdpmzahlrshws.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFlanhhcXFmZHBtemFobHJzaHdzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NzA1NTk1MCwiZXhwIjoyMDkyNjMxOTUwfQ.y01LkTiXSfLpvObwNoh2WFn3yZ1aMlczLIVneKIw4NM

