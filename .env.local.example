# =============================================================
# LIVIA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite .env.local — ele está no .gitignore
# =============================================================

# -------------------------------------------------------------
# Supabase
# Settings > API no painel do Supabase
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------------------------
# Gateway (livia-avocado/gateway)
# GATEWAY_URL: URL base sem path (ex: https://livia-gw.online24por7.ai)
# GATEWAY_API_KEY: chave Bearer para /v2/send, /presence, /notify
# -------------------------------------------------------------
GATEWAY_URL=https://seu-gateway.dominio.com.br
GATEWAY_API_KEY=coloque-aqui-a-chave-do-gateway

# -------------------------------------------------------------
# Evolution API — gerenciamento de instâncias
# Usado pelo app para criar/conectar/configurar instâncias WhatsApp.
# O envio de mensagens em produção vai pelo gateway, não por aqui.
# EVOLUTION_INSTANCE_WEBHOOK_URL: URL que a Evolution vai chamar para eventos
#   (aponta para o gateway: https://seu-gateway.dominio.com.br/webhook/evolution)
# EVOLUTION_WEBHOOK_SECRET: token validado em /api/configuracoes/conexoes/webhook
# -------------------------------------------------------------
EVOLUTION_API_BASE_URL=https://sua-evolution.dominio.com.br
EVOLUTION_API_KEY=sua-api-key-global-da-evolution
EVOLUTION_INSTANCE_WEBHOOK_URL=https://seu-gateway.dominio.com.br/webhook/evolution
EVOLUTION_WEBHOOK_SECRET=token-secreto-para-validar-webhook-da-evolution

# -------------------------------------------------------------
# Meta WhatsApp Cloud API
# META_WEBHOOK_VERIFY_TOKEN: token de verificação do webhook Meta
#   (deve ser igual ao META_VERIFY_TOKEN configurado no gateway)
# -------------------------------------------------------------
META_WEBHOOK_VERIFY_TOKEN=seu-token-de-verificacao-meta

# -------------------------------------------------------------
# n8n — Webhooks de controle de IA e conversas
# N8N_BASE_URL: URL base da instância n8n (sem barra no final)
# Os paths abaixo são relativos a essa base
# -------------------------------------------------------------
N8N_BASE_URL=https://seu-n8n.dominio.com.br
N8N_PAUSE_IA_WEBHOOK=/webhook/livia/pause-ia
N8N_RESUME_IA_WEBHOOK=/webhook/livia/resume-ia
N8N_RESUME_CONVERSATION_WEBHOOK=/webhook/livia/resume-conversation
N8N_NEUROCORE_QUERY_WEBHOOK=/webhook/dev_question_base_conhecimento

# n8n — Webhooks de base de conhecimento (Synapse)
N8N_SYNC_SYNAPSE_WEBHOOK=/webhook/livia/sync-synapse
N8N_DELETE_SYNAPSE_EMBEDDINGS_WEBHOOK=/webhook/livia/delete-synapse-embeddings
N8N_TOGGLE_SYNAPSE_EMBEDDINGS_WEBHOOK=/webhook/livia/toggle-synapse-embeddings
N8N_INACTIVATE_BASE_WEBHOOK=/webhook/livia/inactivate-base

# n8n — URLs de vetores da base de conhecimento (URLs completas com fallback hardcoded)
N8N_CREATE_BASE_VECTOR_URL=https://seu-n8n.dominio.com.br/webhook/livia/create-base-vector
N8N_UPDATE_BASE_VECTOR_URL=https://seu-n8n.dominio.com.br/webhook/livia/update-base-vector
N8N_DELETE_BASE_VECTOR_URL=https://seu-n8n.dominio.com.br/webhook/livia/delete-base-vector
N8N_ENABLE_BASE_VECTOR_URL=https://seu-n8n.dominio.com.br/webhook/livia/enable-base-vector
N8N_DISABLE_BASE_VECTOR_URL=https://seu-n8n.dominio.com.br/webhook/livia/disable-base-vector

# n8n — Onboarding conversacional
# N8N_ONBOARDING_CHAT_API_KEY: header apikey enviado ao webhook de chat do onboarding
N8N_ONBOARDING_CHAT_WEBHOOK=/webhook/livia/onboarding-chat
N8N_ONBOARDING_CHAT_API_KEY=api-key-do-webhook-de-onboarding

# -------------------------------------------------------------
# Stripe
# dashboard.stripe.com > Developers > API Keys
# STRIPE_WEBHOOK_SECRET: gerado ao criar o webhook endpoint no Stripe
# -------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# Mercado Pago
# mercadopago.com.br > Suas integrações > Credenciais de produção
# MERCADOPAGO_WEBHOOK_SECRET: gerado nas configurações de notificação IPN
# -------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-0000000000
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# Jobs agendados (cron)
# CRON_SECRET: autentica POST /api/admin/metrics/generate (job de métricas diárias)
#   deve ser igual à variável LIVIA_CRON_SECRET no n8n
# SCHEDULING_CRON_SECRET: autentica webhooks de agendamento automático
# Gerar: openssl rand -hex 32
# -------------------------------------------------------------
CRON_SECRET=coloque-aqui-uma-string-aleatoria-segura
SCHEDULING_CRON_SECRET=coloque-aqui-outra-string-aleatoria-segura

# n8n — Webhooks de agendamento automático (chamados pelo cron)
WEBHOOK_N8N_SCHEDULING_AUTOMATIONS=https://seu-n8n.dominio.com.br/webhook/livia/scheduling-automations
WEBHOOK_N8N_SCHEDULING_CONFIRMATION_SWEEP=https://seu-n8n.dominio.com.br/webhook/livia/scheduling-confirmation-sweep
WEBHOOK_N8N_SCHEDULING_EXPIRE_HOLDS=https://seu-n8n.dominio.com.br/webhook/livia/scheduling-expire-holds
WEBHOOK_N8N_SCHEDULING_REENGAGE=https://seu-n8n.dominio.com.br/webhook/livia/scheduling-reengage

# -------------------------------------------------------------
# Mock Modes — Desenvolvimento local sem n8n/neurocore ativos
# true  → usa respostas mockadas
# false → chama os serviços reais
# -------------------------------------------------------------
N8N_MOCK=true
NEUROCORE_MOCK=true
